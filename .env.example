PORT=3000

# SMTP para enviar correos de confirmación al aprobar.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_o_app_password
MAIL_FROM=FotoFest Colombia <no-reply@fotofestcolombia.com>

# Google Drive (subida de archivos de inscripción)
# Comparte la carpeta padre con el correo de la cuenta de servicio.
GOOGLE_DRIVE_PARENT_FOLDER_ID=tu_folder_id_en_drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_LLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
# Opcional: true para enlaces públicos sin iniciar sesión.
GOOGLE_DRIVE_PUBLIC_LINKS=false
